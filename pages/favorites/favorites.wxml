<view class="container">

<view class="title">
  <text class="title-text">⭐ 我的收藏</text>
  <text class="subtitle">保存喜欢的灵感组合</text>
</view>

<view class="favorite-list">

  <view class="empty" wx:if="{{!favorites.length}}">
    <text>暂无收藏组合</text>
  </view>

  <view class="favorite-card" wx:for="{{favorites}}" wx:key="index">

    <view class="favorite-number">
      第{{index+1}}条
    </view>

    <view class="favorite-text">
      {{item}}
    </view>

    <view class="favorite-actions">

      <button
        class="copy-btn"
        bindtap="copyFavorite"
        data-index="{{index}}">
        复制
      </button>

      <button
        class="prompt-btn"
        bindtap="createPrompt"
        data-index="{{index}}">
        生成提示词
      </button>

      <button
        class="delete-btn"
        bindtap="deleteFavorite"
        data-index="{{index}}">
        删除
      </button>

    </view>

  </view>

</view>

</view>