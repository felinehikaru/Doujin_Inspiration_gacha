/* pages/admin/admin.wxss */

.container{
  padding:30rpx;
  min-height:100vh;
  background:#f8f6fa;
}

.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30rpx;
}

.title{
  font-size:36rpx;
  font-weight:700;
  color:#513068;
}

.count{
  font-size:26rpx;
  color:#7b3ee6;
}

.empty{
  text-align:center;
  padding:80rpx 0;
  color:#999;
  font-size:28rpx;
}

.entry-card{
  background:#fff;
  border-radius:18rpx;
  padding:26rpx;
  margin-bottom:24rpx;
  box-shadow:0 4rpx 16rpx rgba(0,0,0,0.05);
}

.entry-info{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:16rpx;
}

.entry-text{
  font-size:32rpx;
  font-weight:700;
  color:#513068;
}

.entry-category{
  background:#eee8ff;
  color:#7b3ee6;
  padding:6rpx 16rpx;
  border-radius:30rpx;
  font-size:22rpx;
}

.entry-desc{
  display:block;
  font-size:26rpx;
  color:#67596a;
  line-height:1.6;
  margin-bottom:16rpx;
}

.entry-tags{
  display:flex;
  flex-wrap:wrap;
  gap:10rpx;
  margin-bottom:16rpx;
}

.tag{
  background:#f5f1ff;
  color:#68496f;
  padding:6rpx 14rpx;
  border-radius:20rpx;
  font-size:22rpx;
}

.entry-time{
  display:block;
  font-size:22rpx;
  color:#999;
  margin-bottom:20rpx;
}

.entry-actions{
  display:flex;
  gap:20rpx;
}

.btn-approve,
.btn-reject{
  flex:1;
  border-radius:50rpx;
  font-size:26rpx;
  font-weight:600;
}

.btn-approve{
  background:#7b3ee6;
  color:#fff;
}

.btn-reject{
  background:#fff;
  color:#e85d75;
  border:1rpx solid #e85d75;
}