<view class="container" wx:if="{{showContent}}">

  <view class="help-btn" bindtap="showHelp">
    <text class="help-icon">?</text>
  </view>

  <view class="title">
    <text class="title-text">🎰 同人梗扭蛋机</text>
    <text class="subtitle">随机组合词条，获得创作灵感</text>
  </view>

  <view class="gacha-area">
    <view class="gacha-machine {{isShaking?'shaking':''}}">
      <view class="dome">
        <view class="dome-count">📚 已收录 {{totalCount}} 个词条</view>
        <view class="ball" wx:for="{{balls}}" wx:key="index" style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;background:{{item.color}};"></view>
      </view>
      <view class="body">
        <view class="brand">CP梗扭蛋机</view>
        <view class="knob"></view>
        <view class="slot"></view>
      </view>
    </view>

    <view class="dropped" wx:if="{{results.length}}">
      <view class="capsule-item" wx:for="{{results}}" wx:key="index">
        <view class="capsule">{{item.icon||'🎲'}}</view>
        <view class="chip">
          <text class="chip-label">第{{index+1}}抽</text>
          <text class="chip-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="controls">
    <view class="mode-hint">👇 选择模式开始抽取</view>
    <view class="btn-group">
      <button class="btn btn-random" bindtap="spinRandom">🎲 完全随机</button>
      <button class="btn btn-balanced" bindtap="spinBalanced">⚖️ 分类均衡</button>
    </view>

    <view class="btn-row">
      <button class="btn btn-ghost" bindtap="clearCurrentResult">🗑️ 清空当前</button>
      <button class="btn btn-upload" bindtap="showUploadModal">📤 上传词条</button>
      <button class="btn btn-view" bindtap="showEntriesList">📖 所有词条</button>
    </view>

    <view class="btn-row">
      <button class="btn btn-prompt" bindtap="goToPrompt">📝 提示词相关</button>
    </view>
  </view>

  <view class="mode-display">
    <text>当前模式：</text>
    <text class="mode-name">{{modeName}}</text>
    <text class="mode-badge">{{modeBadge}}</text>
  </view>

  <view class="result-area" wx:if="{{results.length}}">
    <view class="result-card" wx:for="{{results}}" wx:key="index">
      <text class="result-title">{{item.text}}</text>
      <text class="result-desc">{{item.desc}}</text>
      <text class="result-category">{{item.category}}</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <text>还没有抽取结果，开始抽取获得灵感</text>
  </view>

  <view class="collect-area" wx:if="{{results.length}}">
    <button class="btn btn-collect" bindtap="collectCurrent">❤️ 收藏组合</button>
  </view>

  <view class="record-entry">

<view 
class="record-btn history-btn"
bindtap="openHistory">
📜 历史记录
</view>

<view 
class="record-btn favorite-btn"
bindtap="showFavorites">
⭐ 查看收藏
</view>

</view>


  <!--帮助弹窗-->
  <view class="help-modal" wx:if="{{showHelpModal}}" bindtap="closeHelpModal">
    <view class="help-modal-content" catchtap="stopClose">

      <view class="help-modal-title">🎯 使用说明</view>

      <text class="help-line">1. 完全随机：随机抽取三个词条</text>
      <text class="help-line">2. 分类均衡：不同分类组合</text>
      <text class="help-line">3. 抽取结果可以生成提示词</text>
      <text class="help-line">4. 支持收藏喜欢的组合</text>

      <button class="btn btn-ghost" bindtap="closeHelpModal">知道了</button>

    </view>
  </view>


  <!--词条列表-->
  <view class="entries-modal" wx:if="{{showEntriesModal}}" bindtap="closeEntriesModal">

    <view class="entries-modal-content" catchtap="stopClose">

      <view class="entries-modal-title">
        📖 全部词条（{{filteredEntriesCount}}条）
      </view>

      <input class="entries-search-input" placeholder="搜索词条" bindinput="onSearchInput" />

      <view class="entries-filter">

        <view class="filter-btn" bindtap="setFilter" data-type="all">全部</view>

        <view class="filter-btn" bindtap="setFilter" data-type="world">世界</view>

        <view class="filter-btn" bindtap="setFilter" data-type="relationship">关系</view>

        <view class="filter-btn" bindtap="setFilter" data-type="character">角色</view>

        <view class="filter-btn" bindtap="setFilter" data-type="conflict">冲突</view>

        <view class="filter-btn" bindtap="setFilter" data-type="scene">场景</view>

        <view class="filter-btn" bindtap="setFilter" data-type="theme">主题</view>

      </view>


      <view class="entry-list">

        <view class="entry-card" wx:for="{{displayEntries}}" wx:key="_id">

          <text class="entry-text">{{item.text}}</text>

          <text class="entry-desc">{{item.desc}}</text>

          <text class="entry-category">{{item.category}}</text>

        </view>

      </view>


      <button class="btn btn-ghost" bindtap="closeEntriesModal">
        关闭
      </button>

    </view>
  </view>
  <!-- 上传词条 -->

  <view class="upload-modal" wx:if="{{showUploadModal}}">

    <view class="upload-content">

      <view class="upload-title">
        📤 上传新词条
      </view>


      <input class="upload-input" placeholder="输入词条名称" value="{{uploadText}}" bindinput="onTextInput" />

      <textarea class="upload-textarea" placeholder="输入词条描述" value="{{uploadDesc}}" bindinput="onDescInput" />

      <picker mode="selector" range="{{categoryOptions}}" range-key="label" bindchange="onCategoryChange">

        <view class="upload-picker">
          {{uploadCategory || '选择分类'}}
        </view>

      </picker>

      <input class="upload-input" placeholder="输入标签，用逗号分隔" value="{{uploadTags}}" bindinput="onTagsInput" />

      <view class="upload-actions">

        <button class="upload-cancel" bindtap="closeUploadModal">
          取消
        </button>


        <button class="upload-submit" bindtap="submitEntry" loading="{{isUploading}}">
          提交
        </button>

      </view>

    </view>

  </view>
</view>

<!--收藏弹窗-->

<view class="favorites-modal" wx:if="{{showFavoritesModal}}">

  <view class="favorites-content">

    <view class="favorites-title">
      ⭐ 我的收藏
    </view>

    <view class="favorites-item" wx:for="{{favorites}}" wx:key="index">

      {{item}}

    </view>

    <button class="btn btn-ghost" bindtap="closeFavoritesModal">
      关闭
    </button>

  </view>

</view>