<!-- pages/index/index.wxml -->

<!-- 页面内容（开局弹窗确认后才显示） -->
<view class="container" wx:if="{{showContent}}">

  <!-- 帮助按钮（左上角） -->
  <view class="help-btn" bindtap="showHelp">
    <text class="help-icon">?</text>
  </view>

  <!-- 标题 -->
  <view class="title">
    <text class="title-text">🎰 同人梗扭蛋机</text>
    <text class="subtitle">抽三个CP梗，生成AI提示词</text>
  </view>

  <!-- 扭蛋机图形区 -->
  <view class="gacha-area">
    <!-- 扭蛋机主体，绑定摇晃动画类 -->
    <view class="gacha-machine {{isShaking ? 'shaking' : ''}}" id="machine">
      <view class="dome">
        <view class="dome-count">📚 已收录 {{totalCount}} 个词条</view>
        <!-- 装饰彩球 -->
        <view class="ball" wx:for="{{balls}}" wx:key="index" style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;background:{{item.color}};"></view>
      </view>
      <view class="body">
        <view class="brand">CP 梗扭蛋机</view>
        <view class="knob"></view>
        <view class="slot"></view>
      </view>
    </view>
    <!-- 掉落的胶囊 -->
    <view class="dropped" wx:if="{{results.length}}">
      <view class="capsule-item" wx:for="{{results}}" wx:key="index">
        <view class="capsule" style="background:{{item.color || '#7b3ee6'}};">{{item.icon || '🎲'}}</view>
        <view class="chip">
          <text class="chip-label">第{{index+1}}抽</text>
          <text class="chip-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 控制区 -->
  <view class="controls">
    <view class="mode-hint">👇 选模式，点抽卡</view>
    <view class="btn-group">
      <button class="btn btn-random" bindtap="spinRandom">🎲 完全随机</button>
      <button class="btn btn-balanced" bindtap="spinBalanced">⚖️ 类型均衡</button>
    </view>
    <view class="btn-row">
      <button class="btn btn-ghost" bindtap="clearHistory">🗑️ 清空记录</button>
      <button class="btn btn-upload" bindtap="showUploadModal">📤 上传词条</button>
      <button class="btn btn-view" bindtap="showEntriesList">📖 所有词条</button>
    </view>
  </view>

  <!-- 当前模式 -->
  <view class="mode-display">
    <text>当前模式：</text>
    <text class="mode-name">{{modeName}}</text>
    <text class="mode-badge">{{modeBadge}}</text>
  </view>

  <!-- 抽卡结果 -->
  <view class="result-area" wx:if="{{results.length}}">
    <view class="result-card" wx:for="{{results}}" wx:key="index">
      <text class="result-title">{{item.text}}</text>
      <text class="result-desc">{{item.desc}}</text>
    </view>
  </view>
  <view class="empty" wx:else>
    <text>还没有抽取结果，按下按钮让灵感转起来</text>
  </view>

  <!-- 提示词 -->
  <view class="prompt-area">
    <view class="section-label">📋 复制提示词</view>
    <view class="prompt-box" wx:if="{{prompt}}">
      <text selectable="true">{{prompt}}</text>
    </view>
    <view class="prompt-empty" wx:else>
      <text>抽取后自动生成AI提示词</text>
    </view>
    <view class="prompt-actions">
      <button class="btn btn-ghost small" bindtap="copyPrompt" wx:if="{{prompt}}">📋 复制</button>
      <button class="btn btn-ghost small" bindtap="regenerate" wx:if="{{prompt}}">🔄 重新生成</button>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-area">
    <view class="section-label">📜 历史记录</view>
    <view class="history-list">
      <text class="history-item" wx:for="{{history}}" wx:key="index">{{item}}</text>
      <text class="history-empty" wx:if="{{!history.length}}">暂无记录</text>
    </view>
  </view>

</view>  <!-- 结束 container -->

<!-- ===== 使用说明自定义弹窗 ===== -->
<view class="help-modal" wx:if="{{showHelpModal}}" bindtap="closeHelpModal">
  <view class="help-modal-content" catchtap="stopPropagation">
    <view class="help-modal-title">🎯 使用说明</view>
    <view class="help-modal-body">
      <text class="help-line">1. 完全随机：从所有词条里随机抽取三个</text>
      <text class="help-line">2. 类型均衡：分别从“背景”“关系”和“事件”</text>
      <text class="help-line">   里各随机抽取一个</text>
      <text class="help-line">3. 抽取后自动生成提示词，点击「复制」</text>
      <text class="help-line">   可粘贴到 AI 工具</text>
      <text class="help-line">4. 点击「重新生成」可基于同一组词条</text>
      <text class="help-line">   重新生成提示词</text>
      <text class="help-line">5. 历史记录保存最近10次抽卡结果</text>
      <text class="help-line" style="margin-top:12rpx;color:#7b3ee6;font-weight:600;">💡 提示：词条库包含背景、关系、情节三大类，共 {{totalCount}} 条</text>
    </view>
    <view class="help-modal-footer">
      <button class="btn btn-ghost" bindtap="closeHelpModal">知道了</button>
    </view>
  </view>
</view>

<!-- ===== 词条列表弹窗 ===== -->
<view class="entries-modal" wx:if="{{showEntriesModal}}" bindtap="closeEntriesModal">
  <view class="entries-modal-content" catchtap="stopPropagation">
    <view class="entries-modal-title">📖 全部词条（{{totalCount}}条）</view>
    <scroll-view class="entries-scroll" scroll-y="true">
      <view class="entry-item" wx:for="{{allEntries}}" wx:key="index">
        <view class="entry-header">
          <text class="entry-name">{{item.text}}</text>
          <text class="entry-type">{{item.type === 'bg' ? '背景' : item.type === 'rel' ? '关系' : '情节'}}</text>
        </view>
        <text class="entry-desc">{{item.desc}}</text>
      </view>
    </scroll-view>
    <view class="entries-modal-footer">
      <button class="btn btn-ghost" bindtap="closeEntriesModal">关闭</button>
    </view>
  </view>
</view>

<!-- ===== 上传词条弹窗 ===== -->
<view class="upload-modal" wx:if="{{showUploadModal}}" bindtap="closeUploadModal">
  <view class="upload-modal-content" catchtap="stopPropagation">
    <view class="upload-modal-title">📤 上传词条</view>
    <view class="upload-form">
      <view class="upload-field">
        <text class="upload-label">词条名 *</text>
        <input class="upload-input" placeholder="输入词条名称" bindinput="onTextInput" value="{{uploadText}}" />
      </view>
      <view class="upload-field">
        <text class="upload-label">类型 *</text>
        <picker bindchange="onTypeChange" range="{{typeOptions}}" range-key="label">
          <view class="upload-picker">{{uploadTypeLabel || '请选择类型'}}</view>
        </picker>
      </view>
      <view class="upload-field">
        <text class="upload-label">描述 *</text>
        <textarea class="upload-textarea" placeholder="输入词条描述（100字以内）" bindinput="onDescInput" value="{{uploadDesc}}" maxlength="100" />
      </view>
      <view class="upload-actions">
        <button class="btn btn-ghost small" bindtap="closeUploadModal">取消</button>
        <button class="btn btn-upload-submit" bindtap="submitEntry" disabled="{{isUploading}}">提交审核</button>
      </view>
    </view>
  </view>
</view>