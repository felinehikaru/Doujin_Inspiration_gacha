<!-- pages/prompt/prompt.wxml -->
<view class="container">

<!-- 返回按钮 -->
<view class="back-btn" bindtap="goBack">
  <text class="back-icon">‹</text>
  <text>返回</text>
</view>

<!-- 当前词条展示 -->
<view class="section">
  <view class="section-label">📌 当前抽到的词条</view>
  <view class="result-cards" wx:if="{{results.length}}">
    <view class="result-card" wx:for="{{results}}" wx:key="index">
      <text class="result-title">{{item.text}}</text>
      <text class="result-desc">{{item.desc}}</text>
    </view>
  </view>
  <view class="empty-hint" wx:else>
    <text>请先在主页抽取词条</text>
  </view>
</view>

<!-- 生成的提示词 -->
<view class="section">
  <view class="section-label">📋 生成的提示词</view>

  <view class="prompt-box" wx:if="{{prompt}}">
    <text selectable="true">{{prompt}}</text>
  </view>

  <view class="prompt-empty" wx:else>
    <text>暂无提示词</text>
  </view>

  <view class="prompt-actions">
    <button class="btn btn-ghost small" bindtap="copyPrompt" wx:if="{{prompt}}">
      📋 复制
    </button>
  </view>
</view>

<!-- 模板入口 -->
<view class="section">
  <view class="template-entry">
    <text>📝 模板编辑器</text>
<button class="btn btn-ghost small" bindtap="openTemplateEditor">
  打开编辑
</button>
  </view>
</view>


<!-- 模板编辑弹窗 -->
<view class="modal-mask" wx:if="{{showTemplateModal}}">
  <view class="modal-box">

    <view class="modal-title">
      📝 编辑提示词模板
    </view>

    <textarea
      class="template-textarea"
      value="{{promptTemplate}}"
      bindinput="onTemplateInput"
      placeholder="请输入模板内容"
    ></textarea>

    <view class="template-actions">
      <button class="btn btn-ghost small" bindtap="resetTemplate">
        恢复默认
      </button>

      <button class="btn btn-primary small" bindtap="saveTemplate">
        保存模板
      </button>
    </view>

    <button class="btn btn-ghost small close-btn" bindtap="closeTemplateEditor">
      关闭
    </button>

  </view>
</view>

</view>