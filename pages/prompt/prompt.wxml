<view class="container">

<view class="header-card">

  <text class="title">
    ⭐ 提示词模板
  </text>

  <text class="subtitle">
    编辑你的创作辅助模板
  </text>

</view>


<view class="template-card">

  <textarea
    class="template-input"
    value="{{promptTemplate}}"
    bindinput="onTemplateInput"
    auto-height="true"
    maxlength="-1">
  </textarea>

</view>


<text class="edit-tip">
  点击文本框可编辑
</text>


<button
  class="copy-btn"
  bindtap="copyPrompt">
  复制内容
</button>


<view class="notice-card">

  <text>
    本程序不提供AI功能，
  </text>

  <text>
    请自行打开辅助软件
  </text>

</view>


</view>