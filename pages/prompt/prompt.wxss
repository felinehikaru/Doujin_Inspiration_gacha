/* pages/prompt/prompt.wxss */

.container {
  padding: 30rpx 30rpx 60rpx;
  min-height: 100vh;
  background: #f8f6fa;
}

/* 返回按钮 */
.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  color: #7b3ee6;
  font-weight: 600;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
}


/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #7b3ee6;
  margin-bottom: 16rpx;
}


/* 词条卡片 */
.result-cards {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 12rpx;
}

.result-card {
  background: #f8f6fa;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 6rpx solid #7b3ee6;
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #513068;
  display: block;
}

.result-desc {
  font-size: 22rpx;
  color: #67596a;
  display: block;
  margin-top: 6rpx;
}

.empty-hint {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx 0;
}


/* 提示词 */
.prompt-box {
  background: #f8f6fa;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #e8e0ec;
  font-size: 26rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
  min-height: 120rpx;
}

.prompt-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 30rpx 0;
}

.prompt-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}


/* 模板入口 */
.template-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #68496f;
}


/* 模板弹窗 */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-box {
  width: 82%;
  max-height: 70vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #513068;
  margin-bottom: 20rpx;
}


/* 模板输入 */
.template-textarea {
  width: 100%;
  min-height: 240rpx;
  max-height: 500rpx;
  border: 2rpx solid #e8e0ec;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.6;
}


/* 按钮 */
.btn {
  border-radius: 60rpx;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
  color: #fff;
  text-align: center;
}

.btn-ghost {
  background: rgba(255,255,255,0.8);
  color: #674868;
  border: 1rpx solid rgba(122,111,240,0.2);
}

.btn-primary {
  background: linear-gradient(135deg,#7a6ff0,#8754ff);
  color: #fff;
}

.small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  flex: none;
}


.template-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}


.close-btn {
  margin-top: 16rpx;
  width: 100%;
}


@media (max-width:400px) {
  .result-cards {
    grid-template-columns:1fr;
  }
}