/* pages/history/history.wxss */

.container{
  padding:30rpx;
  min-height:100vh;
  background:#f8f6fa;
}

.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30rpx;
}

.title{
  font-size:36rpx;
  font-weight:700;
  color:#513068;
}

.count{
  font-size:26rpx;
  color:#7b3ee6;
}

.history-list{
  width:100%;
}

.history-card{
  background:#fff;
  border-radius:18rpx;
  padding:24rpx;
  margin-bottom:20rpx;
  box-shadow:0 4rpx 16rpx rgba(0,0,0,0.05);
}

.history-index{
  display:block;
  font-size:24rpx;
  color:#7b3ee6;
  margin-bottom:12rpx;
}

.history-text{
  display:block;
  font-size:30rpx;
  color:#513068;
  line-height:1.5;
}

.empty{
  text-align:center;
  padding:80rpx 0;
  color:#999;
  font-size:28rpx;
}

.clear-btn{
  margin-top:50rpx;
  background:#e85d75;
  color:#fff;
  border-radius:50rpx;
  font-size:28rpx;
}

.back-btn{
  margin-top:20rpx;
  background:#fff;
  color:#513068;
  border:1rpx solid #513068;
  border-radius:50rpx;
  font-size:28rpx;
}